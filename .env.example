DB_USER=rdadmin
DB_PASSWORD=changeme_dev_only
JWT_SECRET=replace_me_with_at_least_32_chars_of_random_value
CORS_ORIGIN=http://localhost:3000

# Host port the frontend container binds for HTTPS (mapped to nginx:443).
# Override if 443 is already taken on your dev machine. Production deployments
# should keep this at 443 since Cloudflare's edge connects on the standard port.
FRONTEND_TLS_PORT=443

# ── Pairing ──────────────────────────────────────────────────────────────
# LAN-reachable URL the QR code points the agent at. Leave unset for `dotnet
# run` on your dev box (the backend falls back to the request Host header);
# REQUIRED in production behind Cloudflare since the proxy address isn't
# reachable from a phone on the LAN.
PAIRING_BASE_URL=

# ── TURN ─────────────────────────────────────────────────────────────────
# When unset the backend serves an empty iceServers list — host candidates
# only, fine for LAN-only browsers.
#
# TURN_SECRET MUST match `static-auth-secret` in turnserver.conf. The backend
# signs ephemeral credentials with this; coturn validates them against the
# same value.
TURN_SECRET=
TURN_HOSTNAME=
TURN_PORT=3478
TURN_REALM=
# Public IP your router NATs to. coturn embeds this in ICE candidates so
# remote browsers know where to send relayed packets.
TURN_EXTERNAL_IP=

# ── Cloudflare DDNS ──────────────────────────────────────────────────────
# Token must have Zone:DNS:Edit for the zone below. Leave blank to skip DDNS.
CLOUDFLARE_API_TOKEN=
# Comma-separated list of FQDNs to keep pointed at this host's public IP.
# Mix proxied (web UI) and DNS-only (TURN) records via PROXIED below.
CLOUDFLARE_DOMAINS=remote.example.com,turn.example.com
# Per-domain proxy mode. Web UI should be `true` (Cloudflare proxy hides
# your IP and terminates TLS); TURN MUST be `false` (Cloudflare doesn't
# proxy UDP, and grey-cloud means direct DNS to your IP).
CLOUDFLARE_PROXIED=remote.example.com:true,turn.example.com:false
